import pandas as pd
from textblob import TextBlob

# 1. قراءة الملف اللي إحنا قصيناه (تأكد من الاسم)
df = pd.read_csv('processed-data.csv')

# 2. وظيفة بسيطة لتحليل المشاعر
def get_sentiment(text):
    if pd.isna(text): return 'neutral'
    analysis = TextBlob(str(text))
    if analysis.sentiment.polarity > 0:
        return 'positive'
    elif analysis.sentiment.polarity < 0:
        return 'negative'
    else:
        return 'neutral'

# 3. إضافة عمود الـ sentiment (ده اللي الـ Dashboard بتدور عليه)
# تأكد إن اسم عمود المراجعات في ملفك هو 'reviews.text' أو غيره حسب ملفك
column_name = 'reviews.text' # أو 'text' حسب الملف
df['sentiment'] = df[column_name].apply(get_sentiment)

# 4. حفظ الملف بنفس الاسم عشان نرفعه تاني
df.to_csv('processed-data.csv', index=False)
print("✅ الملف جاهز الآن وعمود sentiment تم إضافته!")
